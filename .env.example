# Pick one provider. The Python agent reads these at startup.
# Set A2UI_AGENT_PROVIDER to "anthropic" or "gemini".

A2UI_AGENT_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# Server
A2UI_AGENT_HOST=127.0.0.1
A2UI_AGENT_PORT=8000

# Client (Storybook reads VITE_-prefixed vars only)
VITE_A2UI_AGENT_URL=http://127.0.0.1:8000
