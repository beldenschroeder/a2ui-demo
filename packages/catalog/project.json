{
  "name": "catalog",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/catalog/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run build", "cwd": "packages/catalog" },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run test", "cwd": "packages/catalog" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run lint", "cwd": "packages/catalog" }
    }
  },
  "implicitDependencies": ["button", "card", "text", "text-input"],
  "tags": ["scope:library", "type:catalog"]
}
